{
  "name": "legit",
  "version": "3.1.1",
  "description": "Check that email addresses are really able to accept emails by pinging the DNS and checking for active MX records.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/martyndavies/legit"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/gen-esm-wrapper.js",
    "test": "mocha -r ts-node/register 'test/**/*.ts' && node test/esm-smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/should": "^13.0.0",
    "@types/sinon": "^21.0.0",
    "mocha": "^11.7.5",
    "should": "^13.0.0",
    "sinon": "^21.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "email",
    "check",
    "validation",
    "dns",
    "mx"
  ],
  "author": "Martyn Davies",
  "license": "MIT"
}
